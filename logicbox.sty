\ProvidesPackage{logicbox}[2026/03/03 v2.1 Logic box theorem environments]
\RequirePackage{tcolorbox, amssymb, xcolor, etoolbox, varwidth}

\tcbuselibrary{breakable, skins, theorems}
\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric, calc}

% Options
\newif\iflogicbox@qed
\logicbox@qedfalse
\newif\iflogicbox@sharedcounter
\logicbox@sharedcounterfalse
\DeclareOption{qed}{\logicbox@qedtrue}
\DeclareOption{sharedcounter}{\logicbox@sharedcountertrue}
\ProcessOptions\relax

% Colors: same palette as dangbox and epibox (calc.tex)
% dangbox uses blue!40!black; epibox uses green/orange/red/blue/purple/gray!50!black
\colorlet{logicbox@def}{blue!40!black}
\colorlet{logicbox@thm}{red!50!black}
\colorlet{logicbox@lem}{orange!50!black}
\colorlet{logicbox@cor}{purple!50!black}
\colorlet{logicbox@axiom}{blue!50!black}
\colorlet{logicbox@prop}{green!50!black}
\colorlet{logicbox@rem}{blue!50!black}
\colorlet{logicbox@ex}{green!50!black}
\colorlet{logicbox@exer}{orange!50!black}
\colorlet{logicbox@sol}{gray!50!black}
\colorlet{logicbox@conj}{red!50!black}
\colorlet{logicbox@property}{gray!50!black}
\colorlet{logicbox@proof}{gray!50!black}

% Rounded corners and padding (keep content inside frame)
\tcbset{
  logicbox theorem base/.style={
    enhanced jigsaw, breakable,
    frame hidden, boxrule=0pt,
    before skip=8pt, after skip=8pt,
    boxsep=0pt, left=12pt, right=12pt, top=11pt, bottom=10pt,
    arc=10pt, outer arc=10pt,
    detach title,
    boxed title size=copy,
    varwidth boxed title*=-1.5cm,
    attach boxed title to top left={xshift=10pt, yshift=-1.6mm},
    fonttitle=\sffamily\bfseries\footnotesize,
    separator sign none,
    description delimiters={(}{)},
    pad at break*=2pt,
    before upper={\parindent15pt\noindent},
  },
  logicbox theorem color/.style={
    colback=#1!8!white,
    boxed title style={
      enhanced,
      frame hidden, boxrule=0pt,
      colback=#1!22!white,
      arc=14pt, outer arc=14pt,
      left=8pt, right=8pt, top=3pt, bottom=5pt,
    },
    coltitle=#1!20!black,
  },
  logicbox proof base/.style={
    enhanced jigsaw, breakable,
    frame hidden, boxrule=0pt,
    colback=logicbox@proof!8!white,
    title=Proof,
    fonttitle=\sffamily\bfseries\footnotesize,
    coltitle=logicbox@proof!20!black,
    detach title,
    boxed title size=copy,
    attach boxed title to top left={xshift=10pt, yshift=-1.6mm},
    boxed title style={
      enhanced,
      frame hidden,
      boxrule=0pt,
      colback=logicbox@proof!22!white,
      arc=14pt, outer arc=14pt,
      left=8pt, right=8pt, top=3pt, bottom=5pt,
    },
    arc=10pt, outer arc=10pt,
    before skip=8pt, after skip=8pt,
    boxsep=0pt, left=12pt, right=12pt, top=11pt, bottom=10pt,
    pad at break*=2pt,
    before upper={\parindent15pt\noindent},
  },
}

% Theorem declaration helper. By default every environment has its own counter
% within the current section. With the sharedcounter option, theorem-like
% environments share the theorem counter.
\newcommand{\logicbox@declaretheorem}[4]{%
  \iflogicbox@sharedcounter
    \ifstrequal{#1}{theorem}{%
      \newtcbtheorem[number within=section]{#1}{#2}{logicbox theorem base, logicbox theorem color={#3}}{#4}%
    }{%
      \newtcbtheorem[use counter from=theorem]{#1}{#2}{logicbox theorem base, logicbox theorem color={#3}}{#4}%
    }%
  \else
    \newtcbtheorem[number within=section]{#1}{#2}{logicbox theorem base, logicbox theorem color={#3}}{#4}%
  \fi
}

\newcommand{\newlogicboxtheorem}[4]{%
  \logicbox@declaretheorem{#1}{#2}{#3}{#4}%
}

% Built-in theorem environments
\logicbox@declaretheorem{theorem}{Theorem}{logicbox@thm}{thm}
\logicbox@declaretheorem{definition}{Definition}{logicbox@def}{def}
\logicbox@declaretheorem{lemma}{Lemma}{logicbox@lem}{lem}
\logicbox@declaretheorem{corollary}{Corollary}{logicbox@cor}{cor}
\logicbox@declaretheorem{axiom}{Axiom}{logicbox@axiom}{ax}
\logicbox@declaretheorem{proposition}{Proposition}{logicbox@prop}{prop}
\logicbox@declaretheorem{property}{Property}{logicbox@property}{property}
\logicbox@declaretheorem{remark}{Remark}{logicbox@rem}{rem}
\logicbox@declaretheorem{example}{Example}{logicbox@ex}{ex}
\logicbox@declaretheorem{exercise}{Exercise}{logicbox@exer}{exer}
\logicbox@declaretheorem{solution}{Solution}{logicbox@sol}{sol}
\logicbox@declaretheorem{conjecture}{Conjecture}{logicbox@conj}{conj}

% Proof: smooth corners, extra padding so math/content does not stick out
\newtcolorbox{proof}{
  logicbox proof base,
}
\iflogicbox@qed
  \AtEndEnvironment{proof}{\hfill$\square$}
\fi

% Customization
\newcommand{\logicboxset}[1]{%
  \tcbset{
    logicbox theorem base/.append style={#1},
    logicbox proof base/.append style={#1},
  }%
}
